# pyenv
#   For a library or binary, you wish to ignore these files during development
#   but for an executable/app you may wish to commit them.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or even
#   fail to install them on other platforms. In such cases, Pipfile.lock should be ignored.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   Similar Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm envs
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

